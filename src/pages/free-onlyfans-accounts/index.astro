---
import GuideLanding from "../../components/GuideLanding.astro";
import { getFreeGuideCreators } from "../../lib/guide-pages.mjs";
import { guideFaqs, guideKickers } from "../../lib/guide-public-copy.mjs";
import { metaDescriptions } from "../../lib/site-copy.mjs";

const creators = getFreeGuideCreators(12);
const relatedLinks = [
  {
    href: "/category/free/",
    label: "Free Category",
    description: "Open the main free creator shelf.",
  },
  {
    href: "/categories/",
    label: "Categories",
    description: "Browse the category hub.",
  },
  {
    href: "/creators/",
    label: "All Creators",
    description: "Search every creator profile.",
  },
];
const faqs = [
  {
    question: "What is a free creator account?",
    answer: guideFaqs.freePage,
  },
  {
    question: "How is this different from a free-trial account?",
    answer: guideFaqs.freeVsTrial,
  },
  {
    question: "Are all links completely free?",
    answer: guideFaqs.completelyFree,
  },
  {
    question: "Why do some creators appear in more than one category?",
    answer: guideFaqs.categoryOverlap,
  },
];
---

<GuideLanding
  title="Free OnlyFans Accounts (No Junk Lists) | FreeOnlyFanz"
  description={metaDescriptions.freeAccounts}
  canonicalPath="/free-onlyfans-accounts/"
  h1="Free OnlyFans Accounts Without Digging Through Junk"
  intro="Current free OnlyFans accounts and trial-friendly profiles — curated so you can open real pages fast."
  explanationTitle="A Practical Free Account List"
  paragraphs={[
    "If you are searching for free OnlyFans accounts, you usually want a list that is actually current. This page focuses on creators listed as free or free-trial on FreeOnlyFanz right now.",
    "Each card links to a profile page here first, so you can compare names, photos, and tags before opening the creator's own page.",
  ]}
  creators={creators}
  creatorSectionTitle="Free Creator Accounts"
  creatorSectionKicker={guideKickers.sortedPicks}
  relatedLinks={relatedLinks}
  faqs={faqs}
/>
