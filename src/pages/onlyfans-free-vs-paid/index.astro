---
import GuideLanding from "../../components/GuideLanding.astro";
import { getBestFreeGuideCreators } from "../../lib/guide-pages.mjs";
import { guideFaqs } from "../../lib/guide-public-copy.mjs";
import { metaDescriptions } from "../../lib/site-copy.mjs";

const creators = getBestFreeGuideCreators(8);
const relatedLinks = [
  {
    href: "/category/free/",
    label: "Free Profiles",
    description: "Browse free and free-promo creator pages.",
  },
  {
    href: "/category/free-trial/",
    label: "Free Trials",
    description: "Compare free-trial creator picks.",
  },
  {
    href: "/creators/",
    label: "All Creators",
    description: "Search the full directory.",
  },
  {
    href: "/categories/",
    label: "Categories",
    description: "Browse all current categories.",
  },
];
const faqs = [
  {
    question: "What is a free creator page?",
    answer: guideFaqs.freePage,
  },
  {
    question: "What is a free-trial creator page?",
    answer: guideFaqs.freeTrialPage,
  },
  {
    question: "What is a paid or premium creator page?",
    answer: guideFaqs.paidPage,
  },
  {
    question: "Are all links completely free?",
    answer: guideFaqs.completelyFree,
  },
];
---

<GuideLanding
  title="Free vs Paid Creator Pages | FreeOnlyFanz"
  description={metaDescriptions.freeVsPaid}
  canonicalPath="/onlyfans-free-vs-paid/"
  h1="Free vs Paid Creator Pages"
  intro="Creator pages can be free, free-trial, or paid. FreeOnlyFanz focuses on free and free-trial discovery."
  explanationTitle="The Simple Difference"
  paragraphs={[
    "Free pages generally let you follow or open a creator without paying upfront. Free-trial pages usually offer temporary or promotional access. Paid pages require payment before you get full access.",
    "FreeOnlyFanz highlights free and free-trial creators rather than paid-only profiles. The cards below are from the current directory, and external pages may still include paid content after you open them.",
  ]}
  creators={creators}
  creatorSectionTitle="Start With Free And Trial Picks"
  creatorSectionKicker="Free and free-trial creators from the current directory."
  relatedLinks={relatedLinks}
  faqs={faqs}
/>
