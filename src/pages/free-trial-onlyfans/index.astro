---
import GuideLanding from "../../components/GuideLanding.astro";
import { getFreeTrialGuideCreators } from "../../lib/guide-pages.mjs";
import { guideFaqs, guideKickers } from "../../lib/guide-public-copy.mjs";
import { metaDescriptions } from "../../lib/site-copy.mjs";

const creators = getFreeTrialGuideCreators(12);
const relatedLinks = [
  {
    href: "/guides/free-trial-onlyfans-accounts-2026/",
    label: "Free Trial Accounts 2026",
    description: "Monthly free-trial guide with current offers.",
  },
  {
    href: "/category/free-trial/",
    label: "Free Trial Category",
    description: "Browse the full free-trial shelf.",
  },
  {
    href: "/best-free-onlyfans-creators/",
    label: "Best Free Picks",
    description: "Top free and free-trial starting list.",
  },
  {
    href: "/creators/",
    label: "All Creators",
    description: "Search the full directory.",
  },
];
const faqs = [
  {
    question: "What is a free-trial creator page?",
    answer: guideFaqs.freeTrialPage,
  },
  {
    question: "Is a free trial the same as a permanently free page?",
    answer: guideFaqs.freeVsTrial,
  },
  {
    question: "Are all links completely free?",
    answer: guideFaqs.completelyFree,
  },
  {
    question: "Why do some creators appear in more than one category?",
    answer: guideFaqs.categoryOverlap,
  },
];
---

<GuideLanding
  title="Free Trial OnlyFans Accounts | FreeOnlyFanz"
  description={metaDescriptions.freeTrial}
  canonicalPath="/free-trial-onlyfans/"
  h1="Free Trial OnlyFans Accounts Worth Opening"
  intro="Free-trial OnlyFans pages let you preview a creator before deciding whether their full page is worth your time."
  explanationTitle="How Free-Trial OnlyFans Pages Work"
  paragraphs={[
    "Searching for free trial OnlyFans accounts usually means temporary or promotional access. The exact terms can change on the creator's own page, so read carefully before continuing.",
    "The picks below are creators currently listed with a free-trial or promotional offer on FreeOnlyFanz. Open a profile here first, then visit their page if it looks like a fit.",
  ]}
  creators={creators}
  creatorSectionTitle="Free-Trial Picks"
  creatorSectionKicker={guideKickers.freeTrial}
  relatedLinks={relatedLinks}
  faqs={faqs}
/>
