---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { metaDescriptions } from "../../lib/site-copy.mjs";
---

<BaseLayout
  title="Terms of Use | FreeOnlyFanz"
  description={metaDescriptions.terms}
  canonicalPath="/terms/"
>
  <article class="info-page container">
    <header class="info-page-header">
      <p class="info-eyebrow">Legal</p>
      <h1>Terms of Use</h1>
    </header>
    <div class="info-page-body">
      <p>
        This is a simple overview, not a substitute for legal advice. By using FreeOnlyFanz, you agree to the following in
        addition to common-sense online behavior.
      </p>
      <h2>Age</h2>
      <p>You must be 18 years or older (or the age of majority where you live). If you are not, do not use this site.</p>
      <h2>Independent directory</h2>
      <p>
        FreeOnlyFanz is an independent curated directory. We are not affiliated with any creator platform or the operators of
        pages we link to.
      </p>
      <h2>Outbound links</h2>
      <p>
        Links leave our site. We do not control third-party terms, billing, or content. Your relationship is with those sites.
      </p>
      <h2>Sponsored and affiliate links</h2>
      <p>Some links may be sponsored or earn us a commission. We still expect the site to stay usable and honest.</p>
      <h2>No guarantees</h2>
      <p>
        We provide browsing suggestions “as is.” We do not warrant uninterrupted access, accuracy of every listing, or
        fitness for a particular purpose.
      </p>
      <h2>Changes</h2>
      <p>We may update these terms or the site. Continued use after changes means you accept the updated terms.</p>
    </div>
  </article>
</BaseLayout>
