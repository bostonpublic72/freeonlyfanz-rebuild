---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CreatorCard from "../../components/CreatorCard.astro";
import { getCategoryDefinitions, loadCreators } from "../../lib/creators.mjs";

export function getStaticPaths() {
  return getCategoryDefinitions().map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const creators = loadCreators().filter(category.filter);
const categoryGuideLinks = {
  free: [
    { href: "/free-onlyfans/", label: "Free Creator Pages" },
    { href: "/free-onlyfans-accounts/", label: "Free Creator Accounts" },
  ],
  "free-trial": [{ href: "/free-trial-onlyfans/", label: "Free Trial Guide" }],
  featured: [{ href: "/best-free-onlyfans-creators/", label: "Best Free Picks" }],
};
const guideLinks = categoryGuideLinks[category.slug] || [];
---

<BaseLayout
  title={`${category.title} | FreeOnlyFanz`}
  description={category.description}
  canonicalPath={`/category/${category.slug}/`}
>
  <section class="container category-intro">
    <p class="eyebrow">FreeOnlyFanz Category</p>
    <h1>{category.title}</h1>
    <p>{category.description}</p>
    {guideLinks.length > 0 && (
      <div class="category-links" aria-label="Related guides">
        {guideLinks.map((link) => <a class="pill-link" href={link.href}>{link.label}</a>)}
      </div>
    )}
  </section>

  <section class="section">
    <div class="container">
      <p class="browse-all-meta">
        {creators.length} creator{creators.length === 1 ? "" : "s"} listed
      </p>
      <div class="creator-grid">
        {creators.map((creator) => <CreatorCard creator={creator} />)}
      </div>
    </div>
  </section>
</BaseLayout>
