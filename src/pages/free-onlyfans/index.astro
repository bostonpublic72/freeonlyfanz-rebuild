---
import GuideLanding from "../../components/GuideLanding.astro";
import { getFreeGuideCreators } from "../../lib/guide-pages.mjs";
import { guideFaqs, guideKickers } from "../../lib/guide-public-copy.mjs";
import { metaDescriptions } from "../../lib/site-copy.mjs";

const creators = getFreeGuideCreators(12);
const relatedLinks = [
  {
    href: "/guides/free-latina-onlyfans-creators/",
    label: "Latina Creator Guide",
    description: "Free and free-trial Latina picks.",
  },
  {
    href: "/guides/free-asian-onlyfans-creators/",
    label: "Asian Creator Guide",
    description: "Free and free-trial Asian picks.",
  },
  {
    href: "/creators/",
    label: "All Creators",
    description: "Search the full directory.",
  },
  {
    href: "/guides/",
    label: "All Guides",
    description: "Browse every niche guide.",
  },
];
const faqs = [
  {
    question: "What is a free creator page?",
    answer: guideFaqs.freePage,
  },
  {
    question: "What is a free-trial creator page?",
    answer: guideFaqs.freeTrialPage,
  },
  {
    question: "Are all links completely free?",
    answer: guideFaqs.completelyFree,
  },
  {
    question: "Why do some creators appear in more than one category?",
