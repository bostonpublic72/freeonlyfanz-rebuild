import { guideFaqs, guideKickers } from "../../lib/guide-public-copy.mjs";
import { metaDescriptions } from "../../lib/site-copy.mjs";

const creators = getBestFreeGuideCreators(12);
const relatedLinks = [
  {
    href: "/guides/free-latina-onlyfans-creators/",
    label: "Latina Creator Guide",
    description: "Free and free-trial Latina picks.",
  },
  {
    href: "/guides/free-petite-onlyfans-creators/",
    label: "Petite Creator Guide",
    description: "Petite free and free-trial picks.",
  },
  {
    href: "/free-trial-onlyfans/",
    label: "Free Trial Picks",
    description: "Current free-trial creator pages.",
  },
  {
    href: "/creators/",
    label: "All Creators",
    description: "Search the full directory.",
  },
];
const faqs = [
  {
    question: "How are best free creator picks chosen?",
    answer: guideFaqs.howBestPicksChosen,
  },
  {
    question: "Are these creators official or verified?",
