---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeHero from "../components/home/HomeHero.astro";
import HomeSection from "../components/home/HomeSection.astro";
import { absoluteUrl } from "../lib/site.mjs";
import { getHomepageSections } from "../lib/creators.mjs";

const sections = getHomepageSections();
const SECTION_ANCHOR_IDS = {
  "new-free-creators": "new",
  "featured-free-creators": "featured",
  "free-trial-creators": "free-trials",
  "more-free-picks": "more-free",
  "popular-picks": "popular",
};
const getSection = (id) => sections.find((section) => section.id === id);
const allHomepageCreators = sections.flatMap((section) => section.creators);
const heroBlockedSlugs = new Set(["natatsgirl"]);
const findCreator = (slug) => allHomepageCreators.find((creator) => creator.slug === slug);
const uniqueCreators = (groups, limit = 6) => {
  const seen = new Set();
  const output = [];

  for (const group of groups) {
    for (const creator of group || []) {
      if (!creator?.slug || seen.has(creator.slug) || heroBlockedSlugs.has(creator.slug)) {
        continue;
      }
      seen.add(creator.slug);
      output.push(creator);
      if (output.length >= limit) {
        return output;
      }
    }
  }

  return output;
};

const heroCreators = uniqueCreators(
  [
    [
      getSection("new-free-creators")?.creators?.[0],
      getSection("new-free-creators")?.creators?.[1],
      findCreator("miamicandy"),
    ],
    getSection("new-free-creators")?.creators,
    getSection("featured-free-creators")?.creators,
    getSection("free-trial-creators")?.creators,
    allHomepageCreators,
  ],
  7
);
const sectionCopy = {
  "new-free-creators": {
    title: "New Free Profiles",
    kicker: "Fresh creator pages added to the free discovery shelf.",
    viewHref: "/category/new/",
  },
  "featured-free-creators": {
    title: "Featured Picks",
    kicker: "Standout pages selected for fast, high-intent browsing.",
    viewHref: "/category/featured/",
  },
  "free-trial-creators": {
    title: "Free Trial Picks",
    kicker: "Trial-friendly pages with quick paths to open and compare.",
    viewHref: "/category/free-trial/",
  },
  "more-free-picks": {
    title: "More Free Picks",
    kicker: "Additional free profiles worth keeping in the rotation.",
    viewHref: "/category/free/",
  },
  "popular-picks": {
    title: "Popular Picks",
    kicker: "Established profiles and longtime directory favorites.",
    viewHref: "/category/free/",
  },
};
const enhancedSections = sections.map((section) => ({
  ...section,
  ...(sectionCopy[section.id] || {}),
  anchorId: SECTION_ANCHOR_IDS[section.id] || section.id,
}));
const displaySection = (id, limit, variant = "", randomize = false) => {
  const section = enhancedSections.find((item) => item.id === id);
  return section
    ? {
        ...section,
        variant,
        randomize,
        displayLimit: limit,
        creators: randomize ? section.creators : section.creators.slice(0, limit),
      }
    : null;
};
const newSection = displaySection("new-free-creators", 6, "", true);
const featuredSection = displaySection("featured-free-creators", 5, "", true);
const freeTrialSection = displaySection("free-trial-creators", 4, "panel");
const popularSection = displaySection("popular-picks", 4, "panel");
const moreFreeSection = displaySection("more-free-picks", 6);
const itemListCreators = sections.flatMap((section) => section.creators).slice(0, 20);
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Curated Free Creator Picks",
  itemListElement: itemListCreators.map((creator, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: absoluteUrl(`/creator/${creator.slug}/`),
    name: creator.displayName,
  })),
};
---

<BaseLayout
  title="FreeOnlyFanz - Curated Free Creator Directory"
  description="Browse curated free and free-trial creator picks, new profiles, featured shelves, and more free browsing."
  canonicalPath="/"
>
  <HomeHero creators={heroCreators} />

  {newSection && <HomeSection {...newSection} />}
  {featuredSection && <HomeSection {...featuredSection} />}
  {(freeTrialSection || popularSection) && (
    <section class="split-panels" aria-label="More curated picks">
      <div class="container split-panel-grid">
        {freeTrialSection && <HomeSection {...freeTrialSection} />}
        {popularSection && <HomeSection {...popularSection} />}
      </div>
    </section>
  )}
  {moreFreeSection && <HomeSection {...moreFreeSection} />}

  <script is:inline>
    (function () {
      function shuffle(items) {
        for (var index = items.length - 1; index > 0; index -= 1) {
          var swapIndex = Math.floor(Math.random() * (index + 1));
          var current = items[index];
          items[index] = items[swapIndex];
          items[swapIndex] = current;
        }
        return items;
      }

      document.querySelectorAll("[data-random-creator-grid]").forEach(function (grid) {
        var items = shuffle(Array.from(grid.children));
        var limit = parseInt(grid.dataset.randomLimit || items.length, 10);
        var fragment = document.createDocumentFragment();

        items.forEach(function (item, index) {
          item.hidden = index >= limit;
          fragment.appendChild(item);
        });

        grid.appendChild(fragment);
      });
    })();
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
</BaseLayout>
