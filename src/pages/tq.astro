---
import TqCreatorCard from "../components/TqCreatorCard.astro";
import "../styles/global.css";
import { GA_ID, SITE_NAME, absoluteUrl } from "../lib/site.mjs";
import { metaDescriptions } from "../lib/site-copy.mjs";
import { getTqCreatorRows } from "../lib/creators.mjs";

const tqMainLimit = 12;
const tqMoreLimit = 24;
const { mainCreators, moreCreators } = getTqCreatorRows({
  mainLimit: tqMainLimit,
  moreLimit: tqMoreLimit,
  poolLimit: 60,
});
const title = "Free Profiles — Open Now | FreeOnlyFanz";
const description = metaDescriptions.tq;
const canonicalUrl = absoluteUrl("/tq/");
const heartPath =
  "M24 41S6 30.8 6 16.8C6 10 10.8 6 16.3 6c3.3 0 6.1 1.5 7.7 4.1C25.6 7.5 28.4 6 31.7 6 37.2 6 42 10 42 16.8 42 30.8 24 41 24 41Z";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="noindex, follow" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    {GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ gaId: GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = window.gtag || gtag;
          gtag("js", new Date());
          gtag("config", gaId);
        </script>
      </>
    )}
  </head>
  <body class="tq-page-body">
    <div class="site-shell tq-shell">
      <header class="tq-header tq-header-minimal">
        <nav class="container tq-nav" aria-label="Landing navigation">
          <span class="tq-nav-badge">18+ Free Picks</span>
          <span class="tq-nav-note">Tap a photo to open</span>
        </nav>
      </header>

      <main>
        <section class="tq-hero tq-hero-pop" aria-labelledby="tq-hero-title">
          <div class="container tq-hero-inner tq-hero-inner-pop">
            <p class="tq-eyebrow">Updated hourly</p>
            <h1 id="tq-hero-title">Hand-picked free &amp; trial girls</h1>
            <p class="tq-hero-lede">Only profiles with active free or free-trial access right now. Skip the paywall.</p>
            <div class="tq-chip-row" aria-label="Offer types">
              <span>Free Trial</span>
              <span>Free</span>
              <span>New</span>
              <span>18+ Only</span>
            </div>
          </div>
        </section>

        <section class="section tq-section tq-section-tight" id="start-here">
          <div class="container">
            <div class="section-header tq-section-header-compact">
              <div class="section-copy">
                <h2>Free Trial Picks</h2>
                <p class="section-kicker">Free-trial girls first — higher chance they convert later.</p>
              </div>
            </div>
            <div class="creator-grid tq-grid tq-grid-pop">
              {mainCreators.map((creator, index) => (
                <TqCreatorCard creator={creator} priority={index < 6 ? "primary" : "secondary"} />
              ))}
            </div>
          </div>
        </section>

        {moreCreators.length > 0 && (
          <section class="section tq-section" id="more-free-profiles">
            <div class="container">
              <div class="section-header tq-section-header-compact">
                <div class="section-copy">
                  <h2>More Free Picks</h2>
                  <p class="section-kicker">More curated free and trial profiles worth checking.</p>
                </div>
              </div>
              <div class="creator-grid tq-grid tq-grid-pop tq-more-grid">
                {moreCreators.map((creator) => (
                  <TqCreatorCard creator={creator} />
                ))}
              </div>
            </div>
          </section>
        )}
      </main>

      <footer class="tq-footer tq-footer-minimal">
        <div class="container tq-footer-inner">
          <p>18+ only · Curated free &amp; trial picks · Some links sponsored · Not affiliated with OnlyFans.</p>
        </div>
      </footer>
    </div>

    <script is:inline>
      window.trackTqOutbound = function trackTqOutbound(params) {
        if (typeof window.gtag !== "function") return;
        window.gtag("event", "tq_outbound_click", params || {});
      };

      document.addEventListener("click", function (event) {
        var link = event.target.closest("[data-tq-outbound]");
        if (!link || typeof window.trackTqOutbound !== "function") return;
        window.trackTqOutbound({
          username: link.dataset.username || "",
          creator_name: link.dataset.creatorName || "",
          recommendation: link.dataset.recommendation || "",
          commission_type: link.dataset.commissionType || "",
          offer_type: link.dataset.offerType || "",
          source: "tq",
        });
      });
    </script>
  </body>
</html>
