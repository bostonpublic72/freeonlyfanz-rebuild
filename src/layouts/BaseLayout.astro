---
import "../styles/global.css";
import { GA_ID, SITE_NAME, absoluteUrl } from "../lib/site.mjs";

const {
  title = "FreeOnlyFanz - Curated Free Creator Directory",
  description = "Browse curated free and free-trial creator picks, featured pages, and new finds in one independent directory.",
  canonicalPath = Astro.url.pathname,
} = Astro.props;

const canonicalUrl = absoluteUrl(canonicalPath);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    {GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ gaId: GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = window.gtag || gtag;
          gtag("js", new Date());
          gtag("config", gaId);
        </script>
      </>
    )}
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <nav class="nav" aria-label="Primary navigation">
          <a class="brand" href="/">
            <span class="brand-mark" aria-hidden="true">
              <svg viewBox="0 0 48 48" role="img">
                <path
                  d="M24 41S6 30.8 6 16.8C6 10 10.8 6 16.3 6c3.3 0 6.1 1.5 7.7 4.1C25.6 7.5 28.4 6 31.7 6 37.2 6 42 10 42 16.8 42 30.8 24 41 24 41Z"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
            <span class="brand-copy">
              <span class="brand-name">FreeOnly<span>Fanz</span></span>
            </span>
          </a>
          <div class="nav-links">
            <a href="/#new">New Picks</a>
            <a href="/#free-trials">Free Trials</a>
            <a href="/#featured">Featured</a>
            <a href="/#popular">Popular</a>
            <a href="/categories/">Categories</a>
          </div>
          <form class="site-search" action="/creators/" method="get" role="search">
            <label class="sr-only" for="site-search-input">Search creators</label>
            <input id="site-search-input" type="search" name="q" placeholder="Search creators..." />
            <button type="submit" aria-label="Search creators">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="m21 21-4.3-4.3m2.3-5.2a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                />
              </svg>
            </button>
          </form>
          <a class="nav-cta" href="/creators/">
            Browse All Creators
            <span aria-hidden="true">&gt;</span>
          </a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="container footer-inner">
          <div class="footer-brand-block">
            <a class="brand footer-brand" href="/">
              <span class="brand-mark" aria-hidden="true">
                <svg viewBox="0 0 48 48" role="img">
                  <path
                    d="M24 41S6 30.8 6 16.8C6 10 10.8 6 16.3 6c3.3 0 6.1 1.5 7.7 4.1C25.6 7.5 28.4 6 31.7 6 37.2 6 42 10 42 16.8 42 30.8 24 41 24 41Z"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
              <span class="brand-name">FreeOnly<span>Fanz</span></span>
            </a>
            <p>Curated free and free-trial creator picks. Some links may be sponsored.</p>
            <div class="social-row" aria-label="Social links">
              <a
                href="https://x.com/FreeOnlyFanz_"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Follow on X"
              >
                X
              </a>
            </div>
          </div>
          <div class="footer-column">
            <h2>Quick Links</h2>
            <a href="/#new">New Picks</a>
            <a href="/#free-trials">Free Trials</a>
            <a href="/#featured">Featured</a>
            <a href="/#popular">Popular</a>
            <a href="/categories/">Categories</a>
            <a href="/creators/">Browse All Creators</a>
          </div>
          <div class="footer-column">
            <h2>Guides</h2>
            <a href="/free-onlyfans/">Free Creator Pages</a>
            <a href="/free-trial-onlyfans/">Free Trial Picks</a>
            <a href="/best-free-onlyfans-creators/">Best Free Picks</a>
            <a href="/free-onlyfans-accounts/">Free Creator Accounts</a>
            <a href="/onlyfans-free-vs-paid/">Free vs Paid</a>
          </div>
          <div class="footer-column">
            <h2>Info</h2>
            <a href="/about/">About</a>
            <a href="/how-it-works/">How It Works</a>
            <a href="/faq/">FAQ</a>
            <a href="/contact/">Contact</a>
            <a href="/privacy/">Privacy Policy</a>
            <a href="/terms/">Terms of Use</a>
            <a href="/dmca/">DMCA / Content Removal</a>
          </div>
          <div class="footer-column footer-follow">
            <h2>Follow FreeOnlyFanz</h2>
            <p>New creator picks, free trials, and site updates.</p>
            <a
              class="button footer-follow-cta"
              href="https://x.com/FreeOnlyFanz_"
              target="_blank"
              rel="noopener noreferrer"
            >
              Follow on X
            </a>
          </div>
        </div>
        <div class="footer-legal container">
          <span>18+ only. Some links may be sponsored.</span>
          <span>
            FreeOnlyFanz is an independent curated directory and is not affiliated with any platform.
          </span>
        </div>
      </footer>
    </div>
    <script is:inline>
      window.trackCreatorOutbound = function trackCreatorOutbound(params) {
        if (typeof window.gtag !== "function") return;
        window.gtag("event", "creator_outbound_click", params || {});
      };

      document.addEventListener("click", function (event) {
        var link = event.target.closest("[data-creator-outbound]");
        if (!link || typeof window.trackCreatorOutbound !== "function") return;
        window.trackCreatorOutbound({
          username: link.dataset.username || "",
          creator_name: link.dataset.creatorName || "",
          recommendation: link.dataset.recommendation || "",
          commission_type: link.dataset.commissionType || "",
          offer_type: link.dataset.offerType || "",
        });
      });
    </script>
  </body>
</html>
