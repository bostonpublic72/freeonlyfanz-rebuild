---
import CreatorCard from "../CreatorCard.astro";

const {
  id,
  anchorId,
  title,
  creators = [],
  kicker = "",
  viewHref = "",
  variant = "",
  displayLimit = creators.length,
  randomize = false,
} = Astro.props;
const sectionDomId = anchorId || id;
const sectionClass = ["section", "home-section", variant ? `is-${variant}` : ""].filter(Boolean).join(" ");
const visibleLimit = Math.min(Math.max(Number(displayLimit) || creators.length, 1), creators.length);
const randomGridAttrs = randomize
  ? {
      "data-random-creator-grid": "",
      "data-random-limit": String(visibleLimit),
    }
  : {};
---

{creators.length > 0 && (
  <section class={sectionClass} id={sectionDomId}>
    <div class="container">
      <div class="section-header">
        <div class="section-copy">
          <h2>{title}</h2>
          {kicker && <p class="section-kicker">{kicker}</p>}
        </div>
        {viewHref && <a class="section-link" href={viewHref}>View all</a>}
      </div>
      <div class="creator-grid" {...randomGridAttrs}>
        {creators.map((creator, index) => <CreatorCard creator={creator} hidden={randomize && index >= visibleLimit} />)}
      </div>
    </div>
  </section>
)}
